# ─────────────────────────────────────────────────────────────────────────────
# AssetFlow – Root environment file for docker-compose
#
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App mode ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=assetflow_db
POSTGRES_USER=assetflow
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT secrets (minimum 32 characters each, keep them different!) ────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie signing secret ─────────────────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_at_least_32_chars_long

# ── CORS – URL the browser uses to reach the frontend ─────────────────────────
CLIENT_URL=http://localhost:3000

# ── API URL – baked into the Next.js build AND used at runtime ────────────────
# For server-side fetches (RSC / middleware), Docker DNS resolves "backend"
# to the backend container.  If you expose the API on a public domain,
# change this to that domain, e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://backend:5000/api

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
