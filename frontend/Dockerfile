# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — deps
# Install ALL dependencies (including devDeps needed for the build).
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Install libc compat for Alpine (required by some native deps)
RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json ./

# Full install — devDeps are needed by the Next.js build step
RUN npm ci --ignore-scripts


# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — builder
# Run `next build` to produce the .next/standalone output.
# NEXT_PUBLIC_* variables must be baked in at build time.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Accept the API URL as a build argument so CI/CD can override it.
# Default points to the backend service name in docker-compose.
ARG NEXT_PUBLIC_API_BASE_URL=http://backend:5000/api
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# Copy deps and source
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Produce the standalone server bundle in .next/standalone
RUN npm run build


# ─────────────────────────────────────────────────────────────────────────────
# Stage 3 — final
# Minimal runtime image — only the standalone server + static assets.
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS final

RUN apk add --no-cache dumb-init

# Non-root user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Next.js standalone server listens on PORT (default 3000)
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# ── Copy only what the standalone server needs ─────────────────────────────
# 1. The standalone server itself (includes its own node_modules subset)
COPY --from=builder --chown=appuser:appgroup /app/.next/standalone ./
# 2. Static files served by the built-in file server
COPY --from=builder --chown=appuser:appgroup /app/.next/static ./.next/static
# 3. Public directory (images, icons, robots.txt, etc.)
COPY --from=builder --chown=appuser:appgroup /app/public ./public

USER appuser

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:3000/ || exit 1

ENTRYPOINT ["dumb-init", "--"]
# server.js is the standalone entrypoint generated by Next.js
CMD ["node", "server.js"]
